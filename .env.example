# Banco (PostgreSQL). DATABASE_URL = com pool (runtime); DIRECT_URL = direta (CLI/seed).
DATABASE_URL="postgresql://user:pass@host-pooler/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# Segredo para assinar os JWT (cookie httpOnly). Use um valor longo e aleatório.
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"

# Seed de onboarding (npm run db:seed): conta inicial do gestor.
SEED_ADMIN_NAME="Gestor"
SEED_ADMIN_EMAIL="gestor@exemplo.com"
SEED_ADMIN_PASSWORD="defina-uma-senha"

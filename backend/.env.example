# Banco (PostgreSQL). DATABASE_URL = com pool (runtime); DIRECT_URL = direta (CLI/seed).
DATABASE_URL="postgresql://user:pass@host-pooler/db?sslmode=require"
DIRECT_URL="postgresql://user:pass@host/db?sslmode=require"

# Segredo dos JWT — o MESMO no frontend (que só verifica).
JWT_SECRET="troque-por-um-segredo-longo-e-aleatorio"
SEED_DEFAULT_PASSWORD="senha123"

# Servidor / CORS / Cookie
PORT=4000
FRONTEND_ORIGIN="http://localhost:3000"
# Produção cross-site: COOKIE_SAMESITE=none, COOKIE_SECURE=true
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=false
# COOKIE_DOMAIN=

# Monorepo: frontend/ (Next.js) + backend/ (Express). Cada pasta tem seu
# próprio .gitignore; este cobre o repositório inteiro.

# dependências
**/node_modules/
**/.npm-cache/

# builds / caches
**/.next/
**/out/
**/build/
*.tsbuildinfo

# Prisma — client gerado
backend/src/generated/

# variáveis de ambiente (contêm segredos) — .env.example é versionado
**/.env
**/.env.*
!**/.env.example

# logs / SO / editores / ferramentas
*.log
.DS_Store
.idea/
.vscode/
.claude/

# Next
next-env.d.ts
